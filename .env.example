# Mozilla Data Collective API credentials.
# Copy to .env and paste your key from:
# https://mozilladatacollective.com → Account → Credentials
MDC_API_KEY=

# Where the ~79 GB tar.gz archive is stored (resumable downloads use this path).
# Prefer a path under this repo's gitignored data/ directory.
MDC_DOWNLOAD_PATH=./data/raw

# Optional: SDK log file location (useful if a download stops mid-way).
# MDC_LOG_PATH=./data/raw/datacollective.log
