# Copy to web/.env.local (gitignored) for local API + legal identity.

# Inference mode: mock (default) | api
# VITE_ACCENT_ORACLE_MODE=api
# VITE_ACCENT_ORACLE_API_URL=http://127.0.0.1:8000
# VITE_ACCENT_ORACLE_DEV=1

# Phone LAN (npm run dev:lan): leave API URL empty so Vite proxies to :8000
# under HTTPS (mic needs a secure context; avoids mixed-content blocks).
# VITE_ACCENT_ORACLE_MODE=api
# VITE_ACCENT_ORACLE_API_URL=
# VITE_ACCENT_ORACLE_DEV=1

# Required before public launch (privacy policy + Manage My Data).
# VITE_PRIVACY_EMAIL=you@example.com
# VITE_CONTROLLER_NAME=Nom Cognom

# Optional promo URL on the results share card (defaults to window.location.host).
# VITE_PUBLIC_SITE_URL=https://example.com
